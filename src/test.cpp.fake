#include <SDL2/SDL.h>
#include <iostream>

// Constants
const int SCREEN_WIDTH = 800;
const int SCREEN_HEIGHT = 600;

int main(int argc, char* args[]) {
    // 1. Init SDL
    if (SDL_Init(SDL_INIT_VIDEO) < 0) {
        std::cout << "SDL Init Failed: " << SDL_GetError() << std::endl;
        return 1;
    }

    // 2. Create Window
    SDL_Window* window = SDL_CreateWindow("Arch SDL2 Guide", SDL_WINDOWPOS_UNDEFINED, SDL_WINDOWPOS_UNDEFINED, SCREEN_WIDTH, SCREEN_HEIGHT, SDL_WINDOW_SHOWN);
    if (!window) return 1;

    // 3. Create Renderer
    SDL_Renderer* renderer = SDL_CreateRenderer(window, -1, SDL_RENDERER_ACCELERATED | SDL_RENDERER_PRESENTVSYNC);
    if (!renderer) return 1;

    // Game Variables
    bool isRunning = true;
    SDL_Event event;
    
    // Player Rectangle
    SDL_Rect player = { 350, 250, 50, 50 }; // x, y, w, h

    // 4. Game Loop
    while (isRunning) {
        // --- Event Handling ---
        while (SDL_PollEvent(&event)) {
            if (event.type == SDL_QUIT) {
                isRunning = false;
            }
        }

        // --- Input State Check (Better for movement than PollEvent) ---
        const Uint8* currentKeyStates = SDL_GetKeyboardState(NULL);
        if (currentKeyStates[SDL_SCANCODE_UP]) {
            player.y -= 5;
        }
        if (currentKeyStates[SDL_SCANCODE_DOWN]) {
            player.y += 5;
        }
        if (currentKeyStates[SDL_SCANCODE_LEFT]) {
            player.x -= 5;
        }
        if (currentKeyStates[SDL_SCANCODE_RIGHT]) {
            player.x += 5;
        }

        // --- Render ---
        // Clear screen (Dark Grey)
        SDL_SetRenderDrawColor(renderer, 50, 50, 50, 255);
        SDL_RenderClear(renderer);

        // Draw Player (Cyan)
        SDL_SetRenderDrawColor(renderer, 0, 255, 255, 255);
        SDL_RenderFillRect(renderer, &player);

        // Present
        SDL_RenderPresent(renderer);
    }

    // 5. Cleanup
    SDL_DestroyRenderer(renderer);
    SDL_DestroyWindow(window);
    SDL_Quit();

    return 0;
}
